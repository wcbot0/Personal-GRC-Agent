{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spa.local/schemas/memory-object.schema.json",
  "title": "MemoryObject",
  "type": "object",
  "required": ["id", "type", "source", "sensitivity", "content"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["episodic", "semantic", "procedural", "audit"]
    },
    "source": { "type": "string" },
    "sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "ttl": { "type": ["string", "null"], "format": "date-time" },
    "framework_tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related_objects": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "content": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
