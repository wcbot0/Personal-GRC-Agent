{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "skill",
    "product",
    "vendor",
    "methodology",
    "executive_summary",
    "product_profile",
    "threat_model",
    "implementation_plan",
    "risk_scenarios",
    "summary",
    "control_tags",
    "artifact_file"
  ],
  "properties": {
    "skill": { "const": "risk-analyst" },
    "product": { "type": "string", "minLength": 1 },
    "vendor": { "type": "string", "minLength": 1 },
    "use_case": { "type": "string" },
    "data_classification": { "type": "string" },
    "methodology": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "executive_summary": { "type": "string", "minLength": 50 },
    "product_profile": {
      "type": "object",
      "required": [
        "product_category",
        "deployment_model",
        "architecture_summary",
        "integration_surface",
        "research_sources"
      ],
      "properties": {
        "product_category": { "type": "string", "minLength": 1 },
        "deployment_model": { "type": "string", "minLength": 1 },
        "architecture_summary": { "type": "string", "minLength": 1 },
        "integration_surface": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "research_sources": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "data_stores": { "type": "array", "items": { "type": "string" } },
        "compliance_posture": { "type": "string" }
      }
    },
    "threat_model": {
      "type": "object",
      "required": [
        "scope",
        "assets",
        "trust_boundaries",
        "data_flows",
        "entry_points",
        "threat_actors",
        "stride_threats",
        "attack_paths",
        "assumptions",
        "out_of_scope"
      ],
      "properties": {
        "scope": { "type": "string", "minLength": 1 },
        "assets": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "trust_boundaries": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "data_flows": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "entry_points": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "threat_actors": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "stride_threats": { "type": "array", "minItems": 3, "items": { "type": "object" } },
        "attack_paths": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "assumptions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "out_of_scope": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "implementation_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["phase", "priority", "control", "rationale"],
        "properties": {
          "phase": { "type": "string", "minLength": 1 },
          "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "control": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "suggested_owner": { "type": "string" },
          "risk_ids": { "type": "array", "items": { "type": "string" } },
          "stride_categories": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "risk_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "asset",
          "threat_actor",
          "threat_event",
          "vulnerability",
          "effect",
          "source_finding",
          "fair",
          "nist_800_30",
          "treatment_options"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "asset": { "type": "string", "minLength": 1 },
          "threat_actor": { "type": "string", "minLength": 1 },
          "threat_event": { "type": "string", "minLength": 1 },
          "vulnerability": { "type": "string", "minLength": 1 },
          "effect": { "type": "string", "minLength": 1 },
          "source_finding": { "type": "string", "minLength": 1 },
          "fair": {
            "type": "object",
            "required": [
              "threat_event_frequency",
              "vulnerability",
              "control_strength",
              "loss_event_frequency",
              "primary_loss_magnitude",
              "secondary_loss_magnitude"
            ],
            "properties": {
              "threat_event_frequency": { "type": "integer", "minimum": 1, "maximum": 5 },
              "vulnerability": { "type": "integer", "minimum": 1, "maximum": 5 },
              "control_strength": { "type": "integer", "minimum": 1, "maximum": 5 },
              "loss_event_frequency": { "type": "integer", "minimum": 1, "maximum": 5 },
              "primary_loss_magnitude": { "type": "integer", "minimum": 1, "maximum": 5 },
              "secondary_loss_magnitude": { "type": "integer", "minimum": 1, "maximum": 5 }
            }
          },
          "nist_800_30": {
            "type": "object",
            "required": [
              "likelihood",
              "impact",
              "inherent_risk",
              "residual_risk",
              "risk_level"
            ],
            "properties": {
              "likelihood": { "type": "integer", "minimum": 1, "maximum": 5 },
              "impact": { "type": "integer", "minimum": 1, "maximum": 5 },
              "inherent_risk": { "type": "integer", "minimum": 1, "maximum": 5 },
              "residual_risk": { "type": "integer", "minimum": 1, "maximum": 5 },
              "risk_level": {
                "type": "string",
                "enum": ["low", "moderate", "high"]
              }
            }
          },
          "treatment_options": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["response", "action"],
              "properties": {
                "response": {
                  "type": "string",
                  "enum": ["mitigate", "transfer", "avoid", "accept"]
                },
                "action": { "type": "string", "minLength": 1 },
                "suggested_owner": { "type": "string" },
                "note": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_scenarios", "high_inherent", "high_residual"],
      "properties": {
        "total_scenarios": { "type": "integer", "minimum": 1 },
        "high_inherent": { "type": "integer", "minimum": 0 },
        "high_residual": { "type": "integer", "minimum": 0 },
        "moderate_inherent": { "type": "integer", "minimum": 0 },
        "moderate_residual": { "type": "integer", "minimum": 0 }
      }
    },
    "proposed_tickets": {
      "type": "array",
      "items": { "type": "object" }
    },
    "control_tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "artifact_file": { "type": "string", "minLength": 1 },
    "report_file": { "type": "string" },
    "threat_model_file": { "type": "string" }
  }
}
