{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["skill", "control_mappings", "gaps", "control_tags"],
  "properties": {
    "skill": { "const": "csf-crosswalk" },
    "artifact": { "type": "string" },
    "control_mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["csf_2", "soc2_cc", "iso27001", "nist_800_53"],
        "properties": {
          "artifact_excerpt": { "type": "string" },
          "csf_2": { "type": "string" },
          "soc2_cc": { "type": "string" },
          "iso27001": { "type": "string" },
          "iso27018": { "type": "string" },
          "iso42001": { "type": "string" },
          "nist_800_53": { "type": "string" },
          "coverage": { "type": "string", "enum": ["full", "partial", "none"] },
          "notes": { "type": "string" }
        }
      }
    },
    "gaps": { "type": "array" },
    "control_tags": { "type": "array", "minItems": 1 }
  }
}
