{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["skill", "questionnaire_type", "answers", "control_tags"],
  "properties": {
    "skill": { "const": "questionnaire" },
    "questionnaire_type": { "type": "string" },
    "answers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question_id", "question", "answer", "citations", "confidence", "needs_human"],
        "properties": {
          "question_id": { "type": "string" },
          "question": { "type": "string" },
          "answer": { "type": "string" },
          "citations": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "needs_human": { "type": "boolean" }
        }
      }
    },
    "summary": { "type": "object" },
    "control_tags": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  }
}
