# SPA runtime configuration — copy to .env and fill in locally. Never commit .env.

# Agent runtime (Hermes by default; swap via agent/runtime.config.yaml)
SPA_RUNTIME=hermes

# LLM provider (OpenAI-compatible or Anthropic)
LLM_PROVIDER=openai
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Local embedding service (docker-compose embeddings service)
EMBEDDING_API_BASE=http://localhost:8080
EMBEDDING_MODEL=nomic-embed-text

# Qdrant vector DB
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=spa_brain

# Connector providers (MVP: file-only)
TICKET_PROVIDER=none
GRC_PROVIDER=none
NOTES_PROVIDER=filesystem   # or granola (disabled in MVP)
COMMS_PROVIDER=none         # or slack (disabled in MVP)

# Git identity for agent-owned branches (optional)
GIT_AUTHOR_NAME=SPA Agent
GIT_AUTHOR_EMAIL=spa-agent@localhost
