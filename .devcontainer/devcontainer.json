{
  "name": "Security Personal Assistant",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "qdrant",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "postCreateCommand": "pip install -e . && make selftest",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "redhat.vscode-yaml"
      ]
    }
  },
  "forwardPorts": [6333, 8080]
}
