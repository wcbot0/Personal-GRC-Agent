# Secrets and local state
.env
secrets/
# Live MCP configs may carry local credentials; keep disabled templates tracked.
mcp/*.json
mcp/**/*.json
!mcp/filesystem.json
workspace/.data/
governance/audit-logs/
governance/approval-queue/
governance/eval-history/m3-*.json
inbox/*
!inbox/.gitkeep

# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE / OS
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# Runtime workspace
workspace/drafts/*
!workspace/drafts/.gitkeep
workspace/proposals/*
!workspace/proposals/.gitkeep

# Docker volumes (local bind mounts)
data/
